#!/bin/sh

# Skip on Windows
if [ "$(uname)" = "Windows_NT" ]; then
    echo "Running on Windows. Skipping pre-commit checks."
    exit 0
fi

echo "Running pre-commit quality checks..."

# Check if any lintable files are staged
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kts\?$' || true)
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)

if [ -z "$STAGED_KT_FILES" ] && [ -z "$STAGED_SWIFT_FILES" ]; then
    echo "No staged Kotlin or Swift files, skipping lint checks."
    exit 0
fi

./gradlew :composeApp:lintAll --no-daemon -q 2>&1
if [ $? -ne 0 ]; then
    echo ""
    echo "Lint checks failed. Fix issues before committing."
    echo "  - ktlint auto-fix: ./gradlew :composeApp:ktlintFormat"
    echo "  - detekt report:   composeApp/build/reports/detekt/"
    exit 1
fi

echo "All pre-commit checks passed!"
