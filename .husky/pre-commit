#!/bin/sh

# Skip on Windows
if [ "$(uname)" = "Windows_NT" ]; then
    echo "Running on Windows. Skipping pre-commit checks."
    exit 0
fi

echo "Running pre-commit quality checks..."

# --- 1. ktlint + detekt on staged Kotlin files ---
STAGED_KT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.kts\?$' || true)
if [ -n "$STAGED_KT_FILES" ]; then
    echo "Running ktlint on staged Kotlin files..."
    ./gradlew :composeApp:ktlintCheck --no-daemon -q 2>&1
    if [ $? -ne 0 ]; then
        echo "ktlint failed. Run './gradlew :composeApp:ktlintFormat' to auto-fix."
        exit 1
    fi
    echo "ktlint passed."

    echo "Running detekt on staged Kotlin files..."
    ./gradlew :composeApp:detekt --no-daemon -q 2>&1
    if [ $? -ne 0 ]; then
        echo "detekt failed. Review: composeApp/build/reports/detekt/detekt.html"
        exit 1
    fi
    echo "detekt passed."
else
    echo "No staged Kotlin files, skipping ktlint and detekt."
fi

# --- 2. SwiftLint on staged Swift files ---
STAGED_SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.swift$' || true)
if [ -n "$STAGED_SWIFT_FILES" ]; then
    SWIFTLINT_PATH=""
    for p in /opt/homebrew/bin/swiftlint /usr/local/bin/swiftlint; do
        if [ -x "$p" ]; then
            SWIFTLINT_PATH="$p"
            break
        fi
    done

    if [ -n "$SWIFTLINT_PATH" ]; then
        echo "Running SwiftLint on staged Swift files..."
        $SWIFTLINT_PATH lint --config .swiftlint.yml --strict $STAGED_SWIFT_FILES 2>&1
        if [ $? -ne 0 ]; then
            echo "SwiftLint failed."
            exit 1
        fi
        echo "SwiftLint passed."
    else
        echo "SwiftLint not installed, skipping. Install via: brew install swiftlint"
    fi
else
    echo "No staged Swift files, skipping SwiftLint."
fi

echo "All pre-commit checks passed!"
